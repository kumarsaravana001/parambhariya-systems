# Point the web app at a running Parambhariya API for real persistence + live SSE.
# Leave UNSET to use the built-in browser demo driver (localStorage + client-side
# control simulator) — that's how the public GitHub Pages demo runs.
VITE_API_URL=http://localhost:8787

# Set in CI for GitHub Pages subpath hosting (handled by the deploy workflow):
# VITE_BASE=/parambhariya-systems/
